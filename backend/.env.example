# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Inventory & Order Management API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Database ─────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL. For local Docker use the compose URL:
DATABASE_URL=postgresql+asyncpg://inventory_user:inventory_pass@db:5432/inventory_db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app
